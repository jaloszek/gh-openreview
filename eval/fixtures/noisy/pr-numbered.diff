     1| +"""Loads and validates the metrix service config (billing rates, webhook
     2| +URLs, scheduler intervals) from a JSON file on disk.
     3| +"""
     4| +
     5| +import json
     6| +import logging
     7| +
     8| +from metrix.validators import validate_webhook_url
     9| +
    10| +logger = logging.getLogger(__name__)
    11| +
    12| +DEFAULT_CONFIG_PATH = "/etc/metrix/config.json"
    13| +
    14| +
    15| +class Config:
    16| +    """Thin wrapper around the parsed config dict with defaulted lookups."""
    17| +
    18| +    def __init__(self, data):
    19| +        self._data = data
    20| +
    21| +    @classmethod
    22| +    def load(cls, path=DEFAULT_CONFIG_PATH):
    23| +        """Read and parse the config file at path."""
    24| +        with open(path) as f:
    25| +            data = json.load(f)
    26| +        return cls(data)
    27| +
    28| +    def rate_for(self, kind):
    29| +        """Billing rate in cents for a usage kind, falling back to 1 if unknown."""
    30| +        rates = self._data.get("rates", {})
    31| +        return rates.get(kind, 1)
    32| +
    33| +    def webhook_url(self):
    34| +        """The configured webhook URL for billing notifications, or None."""
    35| +        d = self._data.get("webhook_url")
    36| +        if d and validate_webhook_url(d):
    37| +            return d
    38| +        return None
    39| +
    40| +    def scheduler_poll_seconds(self):
    41| +        """How often the scheduler checks for due jobs."""
    42| +        return self._data.get("scheduler_poll_seconds", 5)
    43| +
    44| +    def export_retention_days(self):
    45| +        """How many days generated exports are kept before rotation."""
    46| +        return self._data.get("export_retention_days", 30)
    47| +
    48| +    def max_page_size(self):
    49| +        """Upper bound on the dashboard page size clients may request."""
    50| +        return self._data.get("max_page_size", 200)
    51| +
    52| +    def notification_recipients(self):
    53| +        """Email addresses to CC on billing notification webhooks."""
    54| +        return self._data.get("notification_recipients", [])
    55| +
    56| +    def validate(self):
    57| +        """Sanity-check required top-level keys; returns a list of problems (empty = OK)."""
    58| +        problems = []
    59| +        if "rates" not in self._data:
    60| +            problems.append("missing 'rates' section")
    61| +        if self.webhook_url() is None and self._data.get("webhook_url"):
    62| +            problems.append("webhook_url is set but not a valid https URL")
    63| +        if self.export_retention_days() <= 0:
    64| +            problems.append("export_retention_days must be positive")
    65| +        if self.max_page_size() <= 0:
    66| +            problems.append("max_page_size must be positive")
    67| +        return problems
    68| +
    69| +    def as_dict(self):
    70| +        """Return a shallow copy of the underlying config data."""
    71| +        return dict(self._data)
