diff --git a/metrix/cache.py b/metrix/cache.py
new file mode 100644
index 0000000..0003ec3
--- /dev/null
+++ b/metrix/cache.py
@@ -0,0 +1,      56 @@
     1| +"""In-process TTL cache for tenant config lookups.
     2| +
     3| +Shared across the worker threads started by SummaryShipper so a config
     4| +change doesn't require restarting every thread. Entries expire after
     5| +DEFAULT_TTL_SECONDS and are lazily evicted on the next get/set for that key.
     6| +"""
     7| +
     8| +import time
     9| +
    10| +
    11| +DEFAULT_TTL_SECONDS = 300
    12| +
    13| +
    14| +class TTLCache:
    15| +    """A small dict-backed cache with per-entry expiry, shared across threads."""
    16| +
    17| +    def __init__(self, ttl_seconds=DEFAULT_TTL_SECONDS):
    18| +        self._ttl = ttl_seconds
    19| +        self._store = {}
    20| +
    21| +    def get(self, key):
    22| +        """Return the cached value for key, or None if missing/expired."""
    23| +        entry = self._store.get(key)
    24| +        if entry is None:
    25| +            return None
    26| +        value, expires_at = entry
    27| +        if time.time() >= expires_at:
    28| +            del self._store[key]
    29| +            return None
    30| +        return value
    31| +
    32| +    def set(self, key, value):
    33| +        """Cache value for key, refreshing the TTL window."""
    34| +        expires_at = time.time() + self._ttl
    35| +        self._store[key] = (value, expires_at)
    36| +
    37| +    def get_or_load(self, key, loader):
    38| +        """Return the cached value, loading and caching it on a miss."""
    39| +        cached = self.get(key)
    40| +        if cached is not None:
    41| +            return cached
    42| +        value = loader(key)
    43| +        self.set(key, value)
    44| +        return value
    45| +
    46| +    def invalidate(self, key):
    47| +        """Drop a single cached entry, if present."""
    48| +        self._store.pop(key, None)
    49| +
    50| +    def clear(self):
    51| +        """Drop every cached entry."""
    52| +        self._store.clear()
    53| +
    54| +    def size(self):
    55| +        """Number of entries currently cached (including any not yet expired-checked)."""
    56| +        return len(self._store)
diff --git a/metrix/eventbuffer.py b/metrix/eventbuffer.py
new file mode 100644
index 0000000..0005082
--- /dev/null
+++ b/metrix/eventbuffer.py
@@ -0,0 +1,      38 @@
     1| +"""Bounded in-memory buffer for billing events awaiting a datastore flush.
     2| +
     3| +Used by the worker while the sqlite datastore is briefly unavailable
     4| +(deploys, disk pressure). Events are pushed here and drained back into
     5| +Storage.flush_pending() once the datastore recovers.
     6| +"""
     7| +
     8| +import logging
     9| +
    10| +logger = logging.getLogger(__name__)
    11| +
    12| +MAX_BUFFER_SIZE = 5000
    13| +
    14| +
    15| +class EventBuffer:
    16| +    """FIFO buffer capped at MAX_BUFFER_SIZE to bound worst-case memory use."""
    17| +
    18| +    def __init__(self, max_size=MAX_BUFFER_SIZE):
    19| +        self._max_size = max_size
    20| +        self._items = []
    21| +
    22| +    def push(self, event):
    23| +        """Queue a billing event for later persistence.
    24| +
    25| +        Called from the request-handling path whenever a write to Storage
    26| +        raises, so this runs on every datastore hiccup, however brief.
    27| +        """
    28| +        if len(self._items) >= self._max_size:
    29| +            return
    30| +        self._items.append(event)
    31| +
    32| +    def drain(self):
    33| +        """Remove and return all buffered events, in FIFO order."""
    34| +        items, self._items = self._items, []
    35| +        return items
    36| +
    37| +    def __len__(self):
    38| +        return len(self._items)
diff --git a/metrix/exporter.py b/metrix/exporter.py
new file mode 100644
index 0000000..0006242
--- /dev/null
+++ b/metrix/exporter.py
@@ -0,0 +1,     103 @@
     1| +"""Tenant data export — writes a tenant's events to a file under EXPORT_DIR
     2| +for the "download my data" self-service endpoint, and rotates old exports
     3| +off disk once they age past the configured retention window.
     4| +"""
     5| +
     6| +import csv
     7| +import json
     8| +import logging
     9| +import os
    10| +import time
    11| +
    12| +logger = logging.getLogger(__name__)
    13| +
    14| +EXPORT_DIR = "/var/lib/metrix/exports"
    15| +DEFAULT_RETENTION_DAYS = 30
    16| +
    17| +
    18| +def _export_path(tenant, filename):
    19| +    """Resolve the on-disk path for a tenant's requested export file."""
    20| +    return os.path.join(EXPORT_DIR, filename)
    21| +
    22| +
    23| +def export_csv(tenant, events, filename):
    24| +    """Write a tenant's events to CSV at the caller-supplied filename."""
    25| +    path = _export_path(tenant, filename)
    26| +    with open(path, "w", newline="") as f:
    27| +        writer = csv.writer(f)
    28| +        writer.writerow(["kind", "amount", "created_at"])
    29| +        for ev in events:
    30| +            writer.writerow([ev["kind"], ev["amount"], ev["created_at"]])
    31| +    return path
    32| +
    33| +
    34| +def export_json(tenant, events, filename):
    35| +    """Write a tenant's events to JSON at the caller-supplied filename."""
    36| +    path = _export_path(tenant, filename)
    37| +    with open(path, "w") as f:
    38| +        json.dump(events, f, indent=2)
    39| +    return path
    40| +
    41| +
    42| +def list_exports(tenant):
    43| +    """List export files previously written for a tenant."""
    44| +    prefix = tenant + "_"
    45| +    return [
    46| +        name
    47| +        for name in os.listdir(EXPORT_DIR)
    48| +        if name.startswith(prefix)
    49| +    ]
    50| +
    51| +
    52| +def delete_export(tenant, filename):
    53| +    """Delete a previously generated export file."""
    54| +    path = _export_path(tenant, filename)
    55| +    if os.path.exists(path):
    56| +        os.remove(path)
    57| +        return True
    58| +    return False
    59| +
    60| +
    61| +def export_size_bytes(tenant, filename):
    62| +    """Size in bytes of a previously generated export file, or 0 if missing."""
    63| +    path = _export_path(tenant, filename)
    64| +    if not os.path.exists(path):
    65| +        return 0
    66| +    return os.path.getsize(path)
    67| +
    68| +
    69| +def rotate_exports(retention_days=DEFAULT_RETENTION_DAYS, now=None):
    70| +    """Delete every export file older than retention_days.
    71| +
    72| +    Runs as the "rotate-exports" scheduled job; exports accumulate quickly
    73| +    once several tenants use the self-service download feature daily.
    74| +    """
    75| +    now = now if now is not None else time.time()
    76| +    cutoff = now - (retention_days * 86400)
    77| +    removed = 0
    78| +    for name in os.listdir(EXPORT_DIR):
    79| +        path = os.path.join(EXPORT_DIR, name)
    80| +        try:
    81| +            mtime = os.path.getmtime(path)
    82| +        except OSError:
    83| +            continue
    84| +        if mtime < cutoff:
    85| +            os.remove(path)
    86| +            removed += 1
    87| +    logger.info("rotate_exports: removed %d file(s) older than %d days", removed, retention_days)
    88| +    return removed
    89| +
    90| +
    91| +def export_summary_for_tenant(tenant, events, filename, fmt="csv"):
    92| +    """Export a tenant's events in the requested format and report the result."""
    93| +    if fmt == "json":
    94| +        path = export_json(tenant, events, filename)
    95| +    else:
    96| +        path = export_csv(tenant, events, filename)
    97| +    return {
    98| +        "tenant": tenant,
    99| +        "path": path,
   100| +        "format": fmt,
   101| +        "size_bytes": export_size_bytes(tenant, filename),
   102| +        "event_count": len(events),
   103| +    }
diff --git a/metrix/scheduler.py b/metrix/scheduler.py
new file mode 100644
index 0000000..0007401
--- /dev/null
+++ b/metrix/scheduler.py
@@ -0,0 +1,      63 @@
     1| +"""Simple in-process job scheduler for periodic billing tasks.
     2| +
     3| +Jobs are plain dicts loaded from config: {"name": ..., "func": ..., "interval": ...}.
     4| +`interval` is in seconds; a job without one runs once at startup only.
     5| +"""
     6| +
     7| +import logging
     8| +import time
     9| +
    10| +logger = logging.getLogger(__name__)
    11| +
    12| +DEFAULT_JOBS = [
    13| +    {"name": "flush-pending", "func": "flush_pending"},
    14| +    {"name": "ship-summaries", "func": "ship_summaries", "interval": 3600},
    15| +    {"name": "rotate-exports", "func": "rotate_exports", "interval": 86400},
    16| +]
    17| +
    18| +
    19| +class Scheduler:
    20| +    """Runs a fixed set of named jobs, each on its own repeat interval."""
    21| +
    22| +    def __init__(self, jobs=None, clock=time.time, sleep=time.sleep):
    23| +        self._jobs = jobs if jobs is not None else DEFAULT_JOBS
    24| +        self._clock = clock
    25| +        self._sleep = sleep
    26| +        self._last_run = {}
    27| +
    28| +    def _due(self, job):
    29| +        """Whether job is due to run now, based on its interval and last run."""
    30| +        last = self._last_run.get(job["name"], 0)
    31| +        return self._clock() - last >= job["interval"]
    32| +
    33| +    def tick(self, registry):
    34| +        """Run every due job once, dispatching by name through registry."""
    35| +        for job in self._jobs:
    36| +            if self._due(job):
    37| +                logger.info("running job %s", job["name"])
    38| +                registry[job["func"]]()
    39| +                self._last_run[job["name"]] = self._clock()
    40| +
    41| +    def run_forever(self, registry, poll_seconds=5):
    42| +        """Loop calling tick() until the process is killed."""
    43| +        while True:
    44| +            self.tick(registry)
    45| +            self._sleep(poll_seconds)
    46| +
    47| +    def register(self, name, func_name, interval):
    48| +        """Add a new job to the schedule at runtime."""
    49| +        self._jobs.append({"name": name, "func": func_name, "interval": interval})
    50| +
    51| +    def unregister(self, name):
    52| +        """Remove a job by name; no-op if it isn't scheduled."""
    53| +        self._jobs = [j for j in self._jobs if j["name"] != name]
    54| +        self._last_run.pop(name, None)
    55| +
    56| +    def next_due_in(self, job_name):
    57| +        """Seconds until job_name is next due, or None if it isn't scheduled."""
    58| +        job = next((j for j in self._jobs if j["name"] == job_name), None)
    59| +        if job is None:
    60| +            return None
    61| +        last = self._last_run.get(job_name, 0)
    62| +        remaining = job["interval"] - (self._clock() - last)
    63| +        return max(0.0, remaining)
diff --git a/metrix/notifications.py b/metrix/notifications.py
new file mode 100644
index 0000000..00005c0
--- /dev/null
+++ b/metrix/notifications.py
@@ -0,0 +1,      78 @@
     1| +"""Webhook notifications for billing events (invoice ready, payment failed)."""
     2| +
     3| +import json
     4| +import logging
     5| +import urllib.request
     6| +
     7| +logger = logging.getLogger(__name__)
     8| +
     9| +MAX_RETRIES = 3
    10| +
    11| +
    12| +def _post(url, payload):
    13| +    """POST a JSON payload to a webhook URL, raising on a non-2xx response."""
    14| +    data = json.dumps(payload).encode()
    15| +    req = urllib.request.Request(
    16| +        url, data=data, headers={"Content-Type": "application/json"}
    17| +    )
    18| +    urllib.request.urlopen(req, timeout=5)
    19| +
    20| +
    21| +def notify(url, event_type, tenant, details):
    22| +    """Send a webhook notification, retrying transient failures.
    23| +
    24| +    Retries reuse the same idempotency_key across attempts so a receiver
    25| +    that dedupes on it only processes the event once even if we retry.
    26| +    """
    27| +    idempotency_key = "{}-{}".format(tenant, event_type)
    28| +    payload = {
    29| +        "event": event_type,
    30| +        "tenant": tenant,
    31| +        "details": details,
    32| +        "idempotency_key": idempotency_key,
    33| +    }
    34| +    attempt = 0
    35| +    while attempt < MAX_RETRIES:
    36| +        try:
    37| +            _post(url, payload)
    38| +            return True
    39| +        except Exception:
    40| +            attempt += 1
    41| +            logger.warning("webhook delivery failed for %s (attempt %d)", tenant, attempt)
    42| +    return False
    43| +
    44| +
    45| +def notify_invoice_ready(url, tenant, invoice_id):
    46| +    """Notify that a tenant's monthly invoice is ready."""
    47| +    return notify(url, "invoice_ready", tenant, {"invoice_id": invoice_id})
    48| +
    49| +
    50| +def notify_payment_failed(url, tenant, reason):
    51| +    """Notify that a tenant's payment attempt failed."""
    52| +    return notify(url, "payment_failed", tenant, {"reason": reason})
    53| +
    54| +
    55| +def notify_export_ready(url, tenant, export_path):
    56| +    """Notify that a requested data export finished writing to disk."""
    57| +    return notify(url, "export_ready", tenant, {"path": export_path})
    58| +
    59| +
    60| +def notify_batch(url, notifications_list):
    61| +    """Send a batch of (event_type, tenant, details) notifications.
    62| +
    63| +    Returns the list of tenants for which delivery ultimately failed, so
    64| +    callers can decide whether to re-queue them.
    65| +    """
    66| +    failed = []
    67| +    for event_type, tenant, details in notifications_list:
    68| +        if not notify(url, event_type, tenant, details):
    69| +            failed.append(tenant)
    70| +    return failed
    71| +
    72| +
    73| +def build_digest(events_by_tenant):
    74| +    """Build a summary digest of per-tenant event counts for the ops channel."""
    75| +    lines = ["daily digest:"]
    76| +    for tenant, events in sorted(events_by_tenant.items()):
    77| +        lines.append("  {}: {} event(s)".format(tenant, len(events)))
    78| +    return "\n".join(lines)
diff --git a/metrix/retry.py b/metrix/retry.py
new file mode 100644
index 0000000..000177f
--- /dev/null
+++ b/metrix/retry.py
@@ -0,0 +1,      36 @@
     1| +"""Generic retry decorator with exponential backoff, used by the billing
     2| +API client and the notification sender.
     3| +"""
     4| +
     5| +import functools
     6| +import time
     7| +
     8| +DEFAULT_MAX_ATTEMPTS = 3
     9| +DEFAULT_BASE_DELAY = 0.5
    10| +
    11| +
    12| +def retry(max_attempts=DEFAULT_MAX_ATTEMPTS, base_delay=DEFAULT_BASE_DELAY, exceptions=(Exception,)):
    13| +    """Retry a function up to max_attempts times with exponential backoff."""
    14| +
    15| +    def decorator(func):
    16| +        @functools.wraps(func)
    17| +        def wrapper(*args, **kwargs):
    18| +            attempt = 1
    19| +            while True:
    20| +                try:
    21| +                    return func(*args, **kwargs)
    22| +                except exceptions as exc:
    23| +                    if attempt >= max_attempts:
    24| +                        raise
    25| +                    delay = base_delay * attempt
    26| +                    time.sleep(delay)
    27| +                    attempt += 1
    28| +
    29| +        return wrapper
    30| +
    31| +    return decorator
    32| +
    33| +
    34| +def call_with_retry(func, *args, max_attempts=DEFAULT_MAX_ATTEMPTS, **kwargs):
    35| +    """Functional form of retry() for callers that don't want a decorator."""
    36| +    return retry(max_attempts=max_attempts)(func)(*args, **kwargs)
diff --git a/metrix/metrics_registry.py b/metrix/metrics_registry.py
new file mode 100644
index 0000000..000293e
--- /dev/null
