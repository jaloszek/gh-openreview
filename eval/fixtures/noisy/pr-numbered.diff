@@ -0,0 +1,      37 @@
     1| +"""In-process registry of counters/gauges reported to the internal metrics
     2| +sink alongside billing summaries.
     3| +"""
     4| +
     5| +import logging
     6| +
     7| +logger = logging.getLogger(__name__)
     8| +
     9| +
    10| +class MetricsRegistry:
    11| +    """Tracks named counters and gauges, tagged by a unit for display."""
    12| +
    13| +    def __init__(self):
    14| +        self._counters = {}
    15| +        self._gauges = {}
    16| +
    17| +    def increment(self, name, amount=1, unit="count"):
    18| +        """Increment a named counter by amount."""
    19| +        key = name
    20| +        self._counters[key] = self._counters.get(key, 0) + amount
    21| +
    22| +    def set_gauge(self, name, value, unit="count"):
    23| +        """Set a named gauge to value."""
    24| +        key = name
    25| +        self._gauges[key] = value
    26| +
    27| +    def snapshot(self):
    28| +        """Return a flat dict of every counter and gauge, for the /metrics endpoint."""
    29| +        out = {}
    30| +        out.update(self._counters)
    31| +        out.update(self._gauges)
    32| +        return out
    33| +
    34| +    def reset(self):
    35| +        """Zero every counter and clear every gauge (used between test runs)."""
    36| +        self._counters.clear()
    37| +        self._gauges.clear()
