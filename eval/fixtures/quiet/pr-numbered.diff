new file mode 100644
index 0000000..1a2b3c4
--- /dev/null
+++ b/metrix/cli.py
@@ -0,0 +1,52 @@
     1| +"""Command-line interface for generating tenant usage reports."""
     2| +
     3| +import argparse
     4| +import json
     5| +import sys
     6| +
     7| +from metrix import billing, storage
     8| +
     9| +
    10| +def build_report(tenant, since, store):
    11| +    d = store.events_for_tenant(tenant, since)
    12| +    total = billing.total_usage(d)
    13| +    summary = billing.summarize(d)
    14| +    return {"tenant": tenant, "total_usage": total, "summary": summary}
    15| +
    16| +
    17| +def format_text(report):
    18| +    lines = [
    19| +        "tenant: {}".format(report["tenant"]),
    20| +        "total usage: {}".format(report["total_usage"]),
    21| +    ]
    22| +    for kind, cents in report["summary"].items():
    23| +        lines.append("  {}: {} cents".format(kind, cents))
    24| +    return "\n".join(lines)
    25| +
    26| +
    27| +def format_json(report):
    28| +    return json.dumps(report, indent=2)
    29| +
    30| +
    31| +def main(argv=None):
    32| +    """Parse args, build the tenant report, and print it in the chosen format."""
    33| +    parser = argparse.ArgumentParser(description="Generate a tenant usage report")
    34| +    parser.add_argument("tenant")
    35| +    parser.add_argument("--since", default="1970-01-01")
    36| +    parser.add_argument("--format", choices=["text", "json"], default="text")
    37| +    parser.add_argument("--db-path", default="metrix.db")
    38| +    args = parser.parse_args(argv)
    39| +
    40| +    store = storage.Storage(args.db_path, timeout=30)
    41| +    report = build_report(args.tenant, args.since, store)
    42| +
    43| +    if args.format == "json":
    44| +        output = format_json(report)
    45| +    else:
    46| +        output = format_text(report)
    47| +    print(output)
    48| +    return 0
    49| +
    50| +
    51| +if __name__ == "__main__":
    52| +    sys.exit(main())
