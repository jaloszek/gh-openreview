     7| +/**
     8| + * Tracks a monthly spending limit per category and warns when a category
     9| + * goes over. Limits are optional per category: a category with no
    10| + * configured limit is simply never flagged.
    11| + */
    12| +class BudgetTracker {
    13| +    lateinit var limits: Map<Category, Int>
    14| +
    15| +    fun initialize(limits: Map<Category, Int>) {
    16| +        this.limits = limits
    17| +    }
    18| +
    19| +    /** Cents remaining under the configured limit for [category]. */
    20| +    fun remainingCents(ledger: Ledger, category: Category): Int {
    21| +        val limit = limits[category]!!
    22| +        return limit - ledger.totalForCategory(category)
    23| +    }
    24| +
    25| +    fun isOverBudget(ledger: Ledger, category: Category): Boolean {
    26| +        val limit = limits[category] ?: return false
    27| +        return ledger.totalForCategory(category) > limit
    28| +    }
    29| +
    30| +    /** Loads `CATEGORY:amountDollars` lines into a limits map. */
    31| +    fun loadLimits(lines: List<String>): Map<Category, Int> {
    32| +        val result = mutableMapOf<Category, Int>()
    33| +        for (line in lines) {
    34| +            val parsed = runCatching { parseLimitLine(line) }.getOrNull()
    35| +            if (parsed != null) {
    36| +                result[parsed.first] = parsed.second
    37| +            }
    38| +        }
    39| +        return result
    40| +    }
    41| +
    42| +    private fun parseLimitLine(line: String): Pair<Category, Int> {
    43| +        val parts = line.trim().split(":")
    44| +        val category = Category.valueOf(parts[0].trim().uppercase())
    45| +        val cents = Parser.parseAmountCents(parts[1]) ?: error("bad amount")
    46| +        return category to cents
    47| +    }
    48| +
    49| +    /** True once at least one category has a configured limit. */
    50| +    fun hasAnyLimit(): Boolean = limits.isNotEmpty()
    51| +
    52| +    /** The single category closest to going over its limit, if any is configured. */
    53| +    fun closestToLimit(ledger: Ledger): Category? {
    54| +        var closest: Category? = null
    55| +        var closestRemaining = Int.MAX_VALUE
    56| +        for (category in limits.keys) {
    57| +            val remaining = limits.getValue(category) - ledger.totalForCategory(category)
    58| +            if (remaining < closestRemaining) {
    59| +                closestRemaining = remaining
    60| +                closest = category
    61| +            }
    62| +        }
    63| +        return closest
    64| +    }
    65| +}
    66| +
    67| +/**
    68| + * Shared log of budget alerts, appended to from a fan-out of per-category
    69| + * checks so the CLI can print them all together once every category has
    70| + * been evaluated.
    71| + */
    72| +object BudgetAlerts {
    73| +    val messages = mutableListOf<String>()
    74| +
    75| +    /** Kicks off one check per category concurrently and waits for all of them. */
    76| +    suspend fun checkAllAsync(tracker: BudgetTracker, ledger: Ledger) {
    77| +        val jobs = Category.values().map { category ->
    78| +            GlobalScope.async {
    79| +                if (tracker.isOverBudget(ledger, category)) {
    80| +                    messages.add("over budget: ${Report.displayName(category)}")
    81| +                }
    82| +            }
    83| +        }
    84| +        jobs.forEach { it.await() }
    85| +    }
    86| +}
