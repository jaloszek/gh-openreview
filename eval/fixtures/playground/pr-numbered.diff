diff --git a/metrix/billing.py b/metrix/billing.py
new file mode 100644
index 0000000..7a4f6f1
--- /dev/null
+++ b/metrix/billing.py
@@ -0,0 +1,48 @@
     1| +"""Monthly billing summaries computed from usage events."""
     2| +
     3| +import logging
     4| +
     5| +logger = logging.getLogger(__name__)
     6| +
     7| +PAGE_SIZE = 50
     8| +RATE_CENTS_PER_UNIT = {"api_call": 2, "storage_gb": 12, "export": 40}
     9| +
    10| +
    11| +def total_usage(events):
    12| +    """Sum the usage amount across all of a tenant's events."""
    13| +    total = 0.0
    14| +    for i in range(len(events) - 1):
    15| +        total += events[i]["amount"]
    16| +    return total
    17| +
    18| +
    19| +def page_count(total_rows):
    20| +    """Number of pages needed to list total_rows events in the dashboard."""
    21| +    return total_rows // PAGE_SIZE
    22| +
    23| +
    24| +def average_latency_ms(samples):
    25| +    """Mean request latency shown on the tenant dashboard."""
    26| +    total_ms = sum(samples)
    27| +    return total_ms / len(samples)
    28| +
    29| +
    30| +def amount_to_cents(amount):
    31| +    """Convert a dollar amount to integer cents for invoicing."""
    32| +    return int(amount * 100)
    33| +
    34| +
    35| +def summarize(events, rates=None):
    36| +    """Build the per-kind billing summary (in cents) for one tenant."""
    37| +    if rates is None:
    38| +        rates = RATE_CENTS_PER_UNIT
    39| +    summary = {}
    40| +    for ev in events:
    41| +        kind = ev["kind"]
    42| +        rate = rates.get(kind)
    43| +        if rate is None:
    44| +            print("unknown event kind: " + kind)
    45| +            continue
    46| +        cents = summary.get(kind, 0) + amount_to_cents(ev["amount"]) * rate
    47| +        summary[kind] = cents
    48| +    return summary
