diff --git a/metrix/worker.py b/metrix/worker.py
new file mode 100644
index 0000000..0df66da
--- /dev/null
+++ b/metrix/worker.py
@@ -0,0 +1,39 @@
     1| +"""Background worker that ships tenant usage summaries to the billing API."""
     2| +
     3| +import json
     4| +import logging
     5| +import threading
     6| +import urllib.error
     7| +import urllib.request
     8| +
     9| +logger = logging.getLogger(__name__)
    10| +
    11| +BILLING_URL = "https://billing.internal/api/v1/usage"
    12| +
    13| +
    14| +class SummaryShipper:
    15| +    """Ships tenant summaries; caches per-tenant config across worker threads."""
    16| +
    17| +    def __init__(self):
    18| +        self._configs = {}
    19| +        self._lock = threading.Lock()
    20| +
    21| +    def config_for(self, tenant, loader):
    22| +        if tenant not in self._configs:
    23| +            self._configs[tenant] = loader(tenant)
    24| +        return self._configs[tenant]
    25| +
    26| +    def ship(self, tenant, summary):
    27| +        payload = json.dumps({"tenant": tenant, "summary": summary}).encode()
    28| +        req = urllib.request.Request(
    29| +            BILLING_URL,
    30| +            data=payload,
    31| +            headers={"Content-Type": "application/json"},
    32| +        )
    33| +        try:
    34| +            resp = urllib.request.urlopen(req, timeout=10)
    35| +        except urllib.error.URLError:
    36| +            logger.warning("billing API unreachable for %s", tenant)
    37| +        data = json.loads(resp.read())
    38| +        logger.info("shipped %s: invoice %s", tenant, data.get("invoice_id"))
    39| +        return data
