--- a/users.py
+++ b/users.py
@@ -8,6 +8,12 @@ def get_db():
     return sqlite3.connect("app.db")


+def find_user(conn, username):
+    """Look up a single user row by name."""
+    cur = conn.cursor()
+    query = "SELECT * FROM users WHERE name = '%s'" % username
+    cur.execute(query)
+    return cur.fetchone()
+
+
 def close_db(conn):
     conn.close()
